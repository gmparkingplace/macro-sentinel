"""
Macro Sentinel - Report Generator FINAL
하드 오버라이드 + 뉴스 주입 + 스태그플레이션 감지
"""

import os
import re
import json
import datetime
from groq import Groq

GROQ_API_KEY = os.environ.get("GROQ_API_KEY")
DATA_PATH   = "data/market_data.json"
REPORT_PATH = "data/report.json"
TODAY = datetime.date.today().isoformat()

client = Groq(api_key=GROQ_API_KEY)


def calc_scores(d):
    s = {}

    vix      = d["indices"]["vix"]["close"]
    s2s10    = d["spreads"]["us2s10s"]["value"]
    hy       = d["spreads"]["hy_spread"]["value"]
    us10y    = d["rates"]["us10y"]["value"]
    dxy      = d["fx"]["dxy"]["close"]
    tips     = d["rates"]["tips10y"]["value"]
    unemp    = d["macro"]["unemployment"]["value"]
    gdp      = d["macro"]["gdp_growth"]["value"]
    wti      = d["commodities"]["wti"]["close"]
    gold     = d["commodities"]["gold"]["close"]
    gold_chg = d["commodities"]["gold"]["change_pct"]
    fg       = d["sentiment"]["fear_greed"]["score"]

    # VIX
    if vix is None:          s["vix"] = "gray"
    elif vix < 16:           s["vix"] = "green"
    elif vix < 22:           s["vix"] = "yellow"
    else:                    s["vix"] = "red"
    print(f"  VIX={vix} -> {s['vix']}")

    # HY 크레딧 스프레드
    if hy is None:           s["hy_spread"] = "gray"
    elif hy < 3.5:           s["hy_spread"] = "green"
    elif hy < 5.0:           s["hy_spread"] = "yellow"
    else:                    s["hy_spread"] = "red"
    print(f"  HY={hy} -> {s['hy_spread']}")

    # 10Y 금리
    if us10y is None:        s["rates"] = "gray"
    elif us10y < 4.0:        s["rates"] = "green"
    elif us10y < 4.5:        s["rates"] = "yellow"
    else:                    s["rates"] = "red"
    print(f"  10Y={us10y} -> {s['rates']}")

    # DXY
    if dxy is None:          s["dxy"] = "gray"
    elif dxy < 101:          s["dxy"] = "green"
    elif dxy < 104:          s["dxy"] = "yellow"
    else:                    s["dxy"] = "red"
    print(f"  DXY={dxy} -> {s['dxy']}")

    # TIPS
    if tips is None:         s["tips"] = "gray"
    elif tips < 1.2:         s["tips"] = "green"
    elif tips < 2.0:         s["tips"] = "yellow"
    else:                    s["tips"] = "red"
    print(f"  TIPS={tips} -> {s['tips']}")

    # 금리 곡선
    if s2s10 is None:        s["curve"] = "gray"
    elif s2s10 > 0.2:        s["curve"] = "green"
    elif s2s10 > -0.1:       s["curve"] = "yellow"
    else:                    s["curve"] = "red"
    print(f"  2s10s={s2s10} -> {s['curve']}")

    # 섹터 4주 누적
    tech_4w = d["sectors"].get("tech", {}).get("change_4w")
    fin_4w  = d["sectors"].get("financials", {}).get("change_4w")
    if tech_4w is not None and fin_4w is not None:
        avg_4w = (tech_4w + fin_4w) / 2
        if avg_4w > 3:       s["sector"] = "green"
        elif avg_4w > -1:    s["sector"] = "yellow"
        else:                s["sector"] = "red"
    else:
        avg_4w = None
        s["sector"] = "gray"
    print(f"  섹터4w={avg_4w} -> {s['sector']}")

    # Fear & Greed
    if fg is None:           s["sentiment"] = "gray"
    elif fg < 35:            s["sentiment"] = "green"
    elif fg < 55:            s["sentiment"] = "yellow"
    else:                    s["sentiment"] = "red"
    print(f"  F&G={fg} -> {s['sentiment']}")

    # 실업률
    if unemp is None:        s["unemployment"] = "gray"
    elif unemp < 4.2:        s["unemployment"] = "green"
    elif unemp < 5.0:        s["unemployment"] = "yellow"
    else:                    s["unemployment"] = "red"
    print(f"  실업률={unemp} -> {s['unemployment']}")

    # 유가 WTI
    if wti is None:          s["oil"] = "gray"
    elif wti < 75:           s["oil"] = "green"
    elif wti < 85:           s["oil"] = "yellow"
    else:                    s["oil"] = "red"
    print(f"  WTI={wti} -> {s['oil']}")

    # GDP
    if gdp is None:          s["gdp"] = "gray"
    elif gdp > 2.0:          s["gdp"] = "green"
    elif gdp > 0:            s["gdp"] = "yellow"
    else:                    s["gdp"] = "red"
    print(f"  GDP={gdp} -> {s['gdp']}")

    # Gold 안전자산 신호
    if gold is None:         s["gold_signal"] = "gray"
    elif gold > 4000 and (gold_chg or 0) > 0:
                             s["gold_signal"] = "red"
    elif gold > 3000:        s["gold_signal"] = "yellow"
    else:                    s["gold_signal"] = "green"
    print(f"  Gold={gold}({gold_chg}%) -> {s['gold_signal']}")

    # ── 가중 점수 계산 ──
    cw   = {"green": 2, "yellow": 1, "red": 0, "gray": 1}
    core = {"vix", "hy_spread", "rates", "curve", "oil"}
    skip = {"verdict", "overall", "stagflation_risk",
            "ratio", "override_reason", "gold_signal"}

    total = 0
    max_t = 0
    for k, v in s.items():
        if k in skip:
            continue
        w      = 2 if k in core else 1
        total += cw.get(v, 1) * w
        max_t += 2 * w

    ratio = round(total / max_t, 3) if max_t > 0 else 0
    print(f"  ratio(오버라이드전)={ratio}")

    # ── 스태그플레이션 감지 ──
    stagflation = bool(
        wti   is not None and wti   > 85 and
        unemp is not None and unemp > 4.3
    )
    if stagflation:
        print(f"  !! 스태그플레이션: WTI={wti}, 실업률={unemp}%")

    # ── 하드 오버라이드 ──
    hard_avoid = False
    hard_wait  = False
    reasons    = []

    if vix is not None and vix >= 28:
        hard_avoid = True
        reasons.append(f"VIX {vix:.1f} >= 28")

    if wti is not None and wti >= 90:
        hard_avoid = True
        reasons.append(f"WTI ${wti:.1f} >= $90")

    if stagflation:
        hard_avoid = True
        reasons.append(f"스태그플레이션(WTI={wti}, 실업률={unemp}%)")

    if not hard_avoid:
        if vix is not None and vix >= 24:
            hard_wait = True
            reasons.append(f"VIX {vix:.1f} >= 24")
        if s.get("gold_signal") == "red":
            hard_wait = True
            reasons.append(f"Gold 극단위험회피 ${gold:.0f}")

    if reasons:
        print(f"  !! 오버라이드 발동: {reasons}")

    # ── 최종 판정 ──
    if hard_avoid:
        s["overall"] = "red"
        verdict = "AVOID"
    elif hard_wait or ratio < 0.65:
        s["overall"] = "yellow"
        verdict = "WAIT"
    else:
        s["overall"] = "green"
        verdict = "NOW"

    s["verdict"]          = verdict
    s["stagflation_risk"] = stagflation
    s["override_reason"]  = reasons
    s["ratio"]            = ratio

    print(f"  => 최종 판정: {verdict}")
    return s


def groq_analysis(d, s):
    sector_lines = ""
    for name, v in d["sectors"].items():
        c1 = f"{v.get('change_pct'):+.2f}%" if v.get("change_pct") is not None else "N/A"
        c4 = f"{v.get('change_4w'):+.2f}%"  if v.get("change_4w")  is not None else "N/A"
        sector_lines += f"  - {name.upper()}: 1d {c1} / 4w {c4}\n"

    fg = d["sentiment"].get("fear_greed", {})
    fg_str = (f"{fg['score']} ({fg['rating']})"
              if fg.get("score") is not None else "VIX기반 계산중")

    news = d.get("news", [])
    news_block = "\n".join(f"  - {h}" for h in news) if news else "  - 수집실패"

    warn = ""
    if s.get("stagflation_risk"):
        warn += f"\n!! STAGFLATION: WTI=${d['commodities']['wti']['close']}, 실업률={d['macro']['unemployment']['value']}%\n"
    if s.get("override_reason"):
        warn += f"!! 오버라이드: {', '.join(s['override_reason'])}\n"

    prompt = f"""당신은 월스트리트 수석 매크로 전략가입니다.
뉴스와 데이터를 함께 분석하여 JSON만 반환하세요.

[뉴스 {TODAY}]
{news_block}
{warn}
[시장데이터]
S&P500:{d['indices']['sp500']['close']}({d['indices']['sp500']['change_pct']:+.2f}%) Nasdaq:{d['indices']['nasdaq100']['close']}({d['indices']['nasdaq100']['change_pct']:+.2f}%) Russell:{d['indices']['russell']['close']}({d['indices']['russell']['change_pct']:+.2f}%) VIX:{d['indices']['vix']['close']}
2Y:{d['rates']['us2y']['value']}% 10Y:{d['rates']['us10y']['value']}% 2s10s:{d['spreads']['us2s10s']['value']}% TIPS:{d['rates']['tips10y']['value']}% HY:{d['spreads']['hy_spread']['value']}%
CoreCPI:{d['macro']['core_cpi']['value']} 실업률:{d['macro']['unemployment']['value']}% GDP:{d['macro']['gdp_growth']['value']}%
WTI:${d['commodities']['wti']['close']} Gold:${d['commodities']['gold']['close']} DXY:{d['fx']['dxy']['close']} USDKRW:{d['fx']['usdkrw']['close']}
{sector_lines}
Fear&Greed:{fg_str}
스코어: VIX:{s['vix']} HY:{s['hy_spread']} 금리:{s['rates']} 곡선:{s['curve']} DXY:{s['dxy']} TIPS:{s['tips']} 섹터:{s['sector']} 심리:{s['sentiment']} 고용:{s['unemployment']} 유가:{s['oil']} GDP:{s['gdp']} Gold:{s['gold_signal']}
판정:{s['verdict']} ratio:{s['ratio']}

[지시]
- 뉴스 맥락 반드시 반영
- 오버라이드 이유를 verdict_reason에 명시
- JSON만 출력 (```없이):

{{"section0_summary":"시장좌표 3줄(뉴스+수치)","section1_fed":"Fed금리 4줄","section2_flow":"달러자금흐름 3줄","section3_sector":"섹터로테이션 3줄","section4_risk":"지정학정책리스크 3줄","bull_case":"강세논거 2가지(수치포함)","bear_case":"약세논거 2가지(수치+뉴스)","verdict_reason":"판정{s['verdict']} 이유 2줄(오버라이드이유명시)","scenario_bull":"강세시나리오+트리거","scenario_base":"기본시나리오","scenario_bear":"약세시나리오+트리거","entry_triggers":["트리거1(수치포함)","트리거2","트리거3"],"key_events":[{{"date":"YYYY-MM-DD","event":"이벤트","impact":"영향"}},{{"date":"YYYY-MM-DD","event":"이벤트","impact":"영향"}},{{"date":"YYYY-MM-DD","event":"이벤트","impact":"영향"}}]}}"""

    try:
        res = client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=[
                {"role": "system", "content": "매크로 전략가. JSON만 출력. 한국어."},
                {"role": "user",   "content": prompt}
            ],
            temperature=0.25,
            max_tokens=2500,
        )
        text = res.choices[0].message.content.strip()
        print(f"Groq 앞150자: {text[:150]}")

        text = re.sub(r"^```json\s*", "", text)
        text = re.sub(r"^```\s*",     "", text)
        text = re.sub(r"\s*```$",     "", text)
        text = text.strip()

        return json.loads(text)

    except Exception as e:
        print(f"Groq 오류: {e}")
        return {
            "section0_summary":"분석실패","section1_fed":"-","section2_flow":"-",
            "section3_sector":"-","section4_risk":"-","bull_case":"-","bear_case":"-",
            "verdict_reason":"AI분석실패","scenario_bull":"-","scenario_base":"-",
            "scenario_bear":"-","entry_triggers":[],"key_events":[]
        }


def generate():
    print(f"\n{'='*50}\n[{TODAY}] 리포트 생성\n{'='*50}")

    with open(DATA_PATH, "r", encoding="utf-8") as f:
        d = json.load(f)

    print("\n[STEP1] 스코어")
    scores = calc_scores(d)

    print("\n[STEP2] Groq 분석")
    analysis = groq_analysis(d, scores)

    report = {"date": TODAY, "data": d,
              "scores": scores, "analysis": analysis,
              "verdict": scores["verdict"]}

    os.makedirs("data", exist_ok=True)
    with open(REPORT_PATH, "w", encoding="utf-8") as f:
        json.dump(report, f, ensure_ascii=False, indent=2)

    print(f"\n{'='*50}")
    print(f"완료: {scores['verdict']} | override={scores['override_reason']}")
    print(f"{'='*50}\n")


if __name__ == "__main__":
    generate()
